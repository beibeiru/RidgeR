#!/bin/sh

# 1. GSL DETECTION
echo "Checking for GSL..."

if ! command -v gsl-config >/dev/null 2>&1; then
    echo "ERROR: GSL is not installed or gsl-config is not in PATH."
    exit 1
fi

GSL_CFLAGS=$(gsl-config --cflags)
GSL_LIBS=$(gsl-config --libs)

echo "GSL found!"
echo "  GSL_CFLAGS: $GSL_CFLAGS"
echo "  GSL_LIBS:   $GSL_LIBS"

# 2. OPENMP DETECTION
echo "Checking for OpenMP support..."

OMP_CFLAGS=""
OMP_LIBS=""
OS=$(uname -s)

if [ "$OS" = "Darwin" ]; then
    # --- macOS Specific Logic ---
    # Apple Clang does not support -fopenmp directly. 
    # It requires -Xpreprocessor -fopenmp and explicit linking to libomp.
    
    if [ -d "/opt/homebrew/opt/libomp" ]; then
        # Apple Silicon (M1/M2/M3) Homebrew
        echo "  Detected macOS (Apple Silicon) with Homebrew libomp."
        OMP_CFLAGS="-Xpreprocessor -fopenmp -I/opt/homebrew/opt/libomp/include"
        OMP_LIBS="-L/opt/homebrew/opt/libomp/lib -lomp"
        
    elif [ -d "/usr/local/opt/libomp" ]; then
        # Intel Mac Homebrew
        echo "  Detected macOS (Intel) with Homebrew libomp."
        OMP_CFLAGS="-Xpreprocessor -fopenmp -I/usr/local/opt/libomp/include"
        OMP_LIBS="-L/usr/local/opt/libomp/lib -lomp"
        
    else
        # Fallback: Try R's default config (might fail on Clang if not configured in ~/.R/Makevars)
        echo "  Homebrew libomp not found in standard locations. Trying R defaults..."
        OMP_CFLAGS=$(R CMD config SHLIB_OPENMP_CFLAGS 2>/dev/null)
        # On Mac, CFLAGS usually isn't enough for linking, but we try.
        OMP_LIBS="" 
    fi

else
    # --- Linux / Standard Logic ---
    # GCC usually handles OpenMP easily via R CMD config
    OMP_CFLAGS=$(R CMD config SHLIB_OPENMP_CFLAGS 2>/dev/null)
    # For GCC, -fopenmp in CFLAGS is often sufficient for linking too, 
    # but strictly speaking, it should be passed to linker. 
    # R usually handles this environment.
    OMP_LIBS=""
fi

# Clean up any potential error messages captured in variables
case "$OMP_CFLAGS" in
    *ERROR*) OMP_CFLAGS="";;
esac

# 3. REPORT AND WRITE
if [ -n "$OMP_CFLAGS" ]; then
    echo "OpenMP enabled."
    echo "  OMP_CFLAGS: $OMP_CFLAGS"
    echo "  OMP_LIBS:   $OMP_LIBS"
else
    echo "WARNING: OpenMP not found. Building single-threaded version."
    # On Mac, print a helpful hint
    if [ "$OS" = "Darwin" ]; then
        echo "  (Hint: On macOS, run 'brew install libomp' if you haven't already)"
    fi
fi

# Create src directory if it doesn't exist (standard safety)
mkdir -p src

# Write Makevars
cat > src/Makevars <<EOF
## Automatically generated by configure
PKG_CFLAGS = $GSL_CFLAGS $OMP_CFLAGS
PKG_LIBS = $GSL_LIBS $OMP_LIBS
EOF

echo "Configuration complete."
