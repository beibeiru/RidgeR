#!/bin/sh

# 1. GSL DETECTION
echo "Checking for GSL..."
if ! command -v gsl-config >/dev/null 2>&1; then
    echo "ERROR: GSL is not installed or gsl-config is not in PATH."
    exit 1
fi
GSL_CFLAGS=$(gsl-config --cflags)
GSL_LIBS=$(gsl-config --libs)

# 2. COMPILER & OPENMP DETECTION
echo "Checking for OpenMP support..."

OMP_CFLAGS=""
OMP_LIBS=""
OS=$(uname -s)

# Get the compiler R is configured to use
R_CC=$(R CMD config CC)

if [ "$OS" = "Darwin" ]; then
    # --- macOS Logic ---
    
    # Check if user is using Homebrew LLVM Clang (common for high-performance R setups)
    if echo "$R_CC" | grep -q "opt/llvm"; then
        echo "  Detected Homebrew LLVM Compiler ($R_CC)."
        # LLVM has its own libomp. We must use that one, NOT the standalone one.
        if [ -d "/opt/homebrew/opt/llvm/lib" ]; then
            OMP_CFLAGS="-fopenmp -I/opt/homebrew/opt/llvm/include"
            # Link directly to LLVM's libomp and set rpath
            OMP_LIBS="/opt/homebrew/opt/llvm/lib/libomp.dylib -Wl,-rpath,/opt/homebrew/opt/llvm/lib"
        else
            # Fallback for LLVM if paths are weird
            OMP_CFLAGS="-fopenmp"
            OMP_LIBS="-lomp"
        fi
        
    else
        # Standard Apple Clang (Xcode)
        echo "  Detected Standard Apple Clang ($R_CC)."
        
        # Look for standalone Homebrew libomp
        if [ -f "/opt/homebrew/opt/libomp/lib/libomp.dylib" ]; then
            # Apple Silicon
            OMP_CFLAGS="-Xpreprocessor -fopenmp -I/opt/homebrew/opt/libomp/include"
            OMP_LIBS="/opt/homebrew/opt/libomp/lib/libomp.dylib -Wl,-rpath,/opt/homebrew/opt/libomp/lib"
        elif [ -f "/usr/local/opt/libomp/lib/libomp.dylib" ]; then
            # Intel Mac
            OMP_CFLAGS="-Xpreprocessor -fopenmp -I/usr/local/opt/libomp/include"
            OMP_LIBS="/usr/local/opt/libomp/lib/libomp.dylib -Wl,-rpath,/usr/local/opt/libomp/lib"
        else
            echo "  Homebrew libomp not found. Trying defaults..."
            OMP_CFLAGS=$(R CMD config SHLIB_OPENMP_CFLAGS 2>/dev/null)
            OMP_LIBS=$(R CMD config SHLIB_OPENMP_CFLAGS 2>/dev/null)
        fi
    fi
else
    # --- Linux Logic ---
    OMP_CFLAGS=$(R CMD config SHLIB_OPENMP_CFLAGS 2>/dev/null)
    OMP_LIBS=$(R CMD config SHLIB_OPENMP_CFLAGS 2>/dev/null)
fi

# Clean up variables
case "$OMP_CFLAGS" in *ERROR*) OMP_CFLAGS="";; esac
case "$OMP_LIBS" in *ERROR*) OMP_LIBS="";; esac

# 3. WRITE MAKEVARS
mkdir -p src

# We use LIBS instead of PKG_LIBS for the OpenMP part to ensure it appears 
# in the right place relative to R's default flags.
cat > src/Makevars <<EOF
## Automatically generated by configure
PKG_CFLAGS = $OMP_CFLAGS $GSL_CFLAGS
PKG_LIBS = $OMP_LIBS $GSL_LIBS
EOF

if [ -n "$OMP_CFLAGS" ]; then
    echo "OpenMP enabled."
    echo "  OMP_CFLAGS: $OMP_CFLAGS"
    echo "  OMP_LIBS:   $OMP_LIBS"
else
    echo "WARNING: OpenMP not found."
fi

echo "Configuration complete."
