#!/bin/sh

# ===========================================================================
# 1. GSL DETECTION
# ===========================================================================
echo ""
echo "Checking for GSL..."

# Define potential locations for gsl-config on macOS/Linux
GSL_CONFIG_EXEC="gsl-config"

# If not in PATH, look in standard Homebrew/MacPorts locations
if ! command -v "$GSL_CONFIG_EXEC" >/dev/null 2>&1; then
    if [ -x "/opt/homebrew/bin/gsl-config" ]; then
        GSL_CONFIG_EXEC="/opt/homebrew/bin/gsl-config"
    elif [ -x "/usr/local/bin/gsl-config" ]; then
        GSL_CONFIG_EXEC="/usr/local/bin/gsl-config"
    elif [ -x "/opt/local/bin/gsl-config" ]; then
        GSL_CONFIG_EXEC="/opt/local/bin/gsl-config"
    fi
fi

# Final check: Can we execute it?
if ! "$GSL_CONFIG_EXEC" --version >/dev/null 2>&1; then
    echo "ERROR: GSL is not installed or gsl-config is not found."
    exit 1
fi

GSL_CFLAGS=$("$GSL_CONFIG_EXEC" --cflags)
GSL_LIBS=$("$GSL_CONFIG_EXEC" --libs)

# ===========================================================================
# 2. COMPILER & OPENMP DETECTION
# ===========================================================================
echo "Checking for OpenMP support..."

OMP_CFLAGS=""
OMP_LIBS=""
OVERRIDE_LDFLAGS=""
OS=$(uname -s)

# Get the compiler R is configured to use
R_CC=$(R CMD config CC 2>/dev/null)
if [ -z "$R_CC" ]; then
    R_CC="gcc"
fi

# ---------------------------------------------------------------------------
# Function to test if OpenMP actually works with given flags
# ---------------------------------------------------------------------------
test_openmp() {
    TEST_CFLAGS="$1"
    TEST_LIBS="$2"
    
    # Create a temporary directory
    TMPDIR=$(mktemp -d 2>/dev/null || mktemp -d -t 'openmptest')
    TESTFILE="$TMPDIR/test_omp.c"
    TESTOUT="$TMPDIR/test_omp"
    
    # Write a simple OpenMP test program
    cat > "$TESTFILE" <<EOF
#include <omp.h>
#include <stdio.h>
int main() {
    int nthreads = 0;
    #pragma omp parallel
    {
        #pragma omp single
        nthreads = omp_get_num_threads();
    }
    printf("%d\\n", nthreads);
    return 0;
}
EOF
    
    # Try to compile
    $R_CC $TEST_CFLAGS -o "$TESTOUT" "$TESTFILE" $TEST_LIBS 2>/dev/null
    RESULT=$?
    
    # Clean up
    rm -rf "$TMPDIR"
    
    return $RESULT
}

# ---------------------------------------------------------------------------
# Platform-specific OpenMP detection
# ---------------------------------------------------------------------------

if [ "$OS" = "Darwin" ]; then
    # --- macOS Specific Logic ---
    
    # Note: On macOS with Apple Clang + Homebrew libomp, there's a known conflict
    # between R's Rinternals.h (#define match Rf_match) and omp.h's use of 'match'
    # as an OpenMP 5.0+ keyword. We fix this by using -include omp.h to force
    # omp.h to be processed BEFORE any R headers.

    # Case A: Homebrew LLVM Clang
    if echo "$R_CC" | grep -q "opt/homebrew/opt/llvm"; then
        LLVM_LIB="/opt/homebrew/opt/llvm/lib"
        if [ -d "$LLVM_LIB" ]; then
            OMP_CFLAGS="-fopenmp -I/opt/homebrew/opt/llvm/include"
            OMP_LIBS="$LLVM_LIB/libomp.dylib -Wl,-rpath,$LLVM_LIB"
            OVERRIDE_LDFLAGS="-L$LLVM_LIB"
        fi

    # Case B: MacPorts LLVM
    elif echo "$R_CC" | grep -q "opt/local/bin"; then
        OMP_CFLAGS="-fopenmp"
        OMP_LIBS="-lomp"

    # Case C: Standard Apple Clang (Xcode) using Homebrew libomp
    else
        if [ -f "/opt/homebrew/opt/libomp/lib/libomp.dylib" ]; then
            # Apple Silicon
            # Use -include omp.h to force omp.h before R headers (fixes match macro conflict)
            OMP_CFLAGS="-Xpreprocessor -fopenmp -I/opt/homebrew/opt/libomp/include -include omp.h"
            OMP_LIBS="/opt/homebrew/opt/libomp/lib/libomp.dylib -Wl,-rpath,/opt/homebrew/opt/libomp/lib"
            OVERRIDE_LDFLAGS="-L/opt/homebrew/opt/libomp/lib"

        elif [ -f "/usr/local/opt/libomp/lib/libomp.dylib" ]; then
            # Intel Mac
            # Use -include omp.h to force omp.h before R headers (fixes match macro conflict)
            OMP_CFLAGS="-Xpreprocessor -fopenmp -I/usr/local/opt/libomp/include -include omp.h"
            OMP_LIBS="/usr/local/opt/libomp/lib/libomp.dylib -Wl,-rpath,/usr/local/opt/libomp/lib"
            OVERRIDE_LDFLAGS="-L/usr/local/opt/libomp/lib"
        else
             # Fallback to R's config
             OMP_CFLAGS=$(R CMD config SHLIB_OPENMP_CFLAGS 2>/dev/null)
             OMP_LIBS=$(R CMD config SHLIB_OPENMP_CFLAGS 2>/dev/null)
        fi
    fi

    # Check for ~/.R/Makevars conflict
    if [ -f "$HOME/.R/Makevars" ]; then
        if grep -q "usr/local.*omp\|lomp" "$HOME/.R/Makevars" 2>/dev/null; then
            CONFLICT_MSG="WARNING: ~/.R/Makevars may conflict with build flags."
        fi
    fi

else
    # --- Linux Logic ---
    
    # First, try R's built-in OpenMP flags
    R_OMP_CFLAGS=$(R CMD config SHLIB_OPENMP_CFLAGS 2>/dev/null)
    
    # Clean up any error messages
    case "$R_OMP_CFLAGS" in *ERROR*|*error*) R_OMP_CFLAGS="";; esac
    
    if [ -n "$R_OMP_CFLAGS" ] && test_openmp "$R_OMP_CFLAGS" "$R_OMP_CFLAGS"; then
        # R's OpenMP flags work
        OMP_CFLAGS="$R_OMP_CFLAGS"
        OMP_LIBS="$R_OMP_CFLAGS"
    elif test_openmp "-fopenmp" "-fopenmp"; then
        # Standard GCC OpenMP flags work
        OMP_CFLAGS="-fopenmp"
        OMP_LIBS="-fopenmp"
    elif test_openmp "-fopenmp" "-lgomp"; then
        # GCC with explicit libgomp
        OMP_CFLAGS="-fopenmp"
        OMP_LIBS="-lgomp"
    elif test_openmp "-qopenmp" "-qopenmp"; then
        # Intel compiler
        OMP_CFLAGS="-qopenmp"
        OMP_LIBS="-qopenmp"
    else
        # OpenMP not available
        OMP_CFLAGS=""
        OMP_LIBS=""
    fi
fi

# Clean up variables (additional safety check)
case "$OMP_CFLAGS" in *ERROR*) OMP_CFLAGS="";; esac
case "$OMP_LIBS" in *ERROR*) OMP_LIBS="";; esac

# ===========================================================================
# 3. WRITE MAKEVARS
# ===========================================================================
mkdir -p src

cat > src/Makevars <<EOF
## Automatically generated by configure
PKG_CFLAGS = $OMP_CFLAGS $GSL_CFLAGS
PKG_LIBS = $OMP_LIBS $GSL_LIBS
EOF

if [ -n "$OVERRIDE_LDFLAGS" ]; then
    cat >> src/Makevars <<EOF

# Override to prioritize the correct OpenMP library path
LDFLAGS = $OVERRIDE_LDFLAGS
EOF
fi

# ===========================================================================
# 4. FINAL STATUS REPORT
# ===========================================================================

echo ""
echo "-------------------------------"
echo "  RidgeR Configuration Summary "
echo "-------------------------------"
echo "  GSL Found:       Yes"

if [ -n "$OMP_CFLAGS" ]; then
    echo "  OpenMP Status:   ENABLED"
    echo "  Execution Mode:  Multi-threaded"
    echo "  Compiler Flags:  $OMP_CFLAGS"
    echo "  Linker Flags:    $OMP_LIBS"
else
    echo "  OpenMP Status:   DISABLED"
    echo "  Execution Mode:  Single-threaded"
    echo "                   (OpenMP not available or compiler incompatible)"
fi

if [ -n "$CONFLICT_MSG" ]; then
    echo ""
    echo "  $CONFLICT_MSG"
fi

echo "-------------------------------"
echo ""
