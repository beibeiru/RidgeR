#!/bin/sh

# 1. GSL DETECTION
echo "Checking for GSL..."
if ! command -v gsl-config >/dev/null 2>&1; then
    echo "ERROR: GSL is not installed or gsl-config is not in PATH."
    exit 1
fi
GSL_CFLAGS=$(gsl-config --cflags)
GSL_LIBS=$(gsl-config --libs)

# 2. COMPILER & OPENMP DETECTION
echo "Checking for OpenMP support..."
OMP_CFLAGS=""
OMP_LIBS=""
OVERRIDE_LDFLAGS=""

OS=$(uname -s)
R_CC=$(R CMD config CC)

if [ "$OS" = "Darwin" ]; then
    # --- macOS Logic ---
    
    if echo "$R_CC" | grep -q "opt/homebrew/opt/llvm"; then
        echo "  Detected Homebrew LLVM Compiler."
        LLVM_LIB="/opt/homebrew/opt/llvm/lib"
        if [ -d "$LLVM_LIB" ]; then
            OMP_CFLAGS="-fopenmp"
            OMP_LIBS="$LLVM_LIB/libomp.dylib -Wl,-rpath,$LLVM_LIB"
            # Override LDFLAGS to prevent conflicts from ~/.R/Makevars
            OVERRIDE_LDFLAGS="-L$LLVM_LIB"
        fi
        
    elif echo "$R_CC" | grep -q "opt/local/bin"; then
        echo "  Detected MacPorts LLVM Compiler."
        OMP_CFLAGS="-fopenmp"
        OMP_LIBS="-lomp"
        
    else
        echo "  Detected Apple Clang."
        if [ -f "/opt/homebrew/opt/libomp/lib/libomp.dylib" ]; then
            OMP_CFLAGS="-Xpreprocessor -fopenmp -I/opt/homebrew/opt/libomp/include"
            OMP_LIBS="/opt/homebrew/opt/libomp/lib/libomp.dylib -Wl,-rpath,/opt/homebrew/opt/libomp/lib"
            OVERRIDE_LDFLAGS="-L/opt/homebrew/opt/libomp/lib"
        elif [ -f "/usr/local/opt/libomp/lib/libomp.dylib" ]; then
            OMP_CFLAGS="-Xpreprocessor -fopenmp -I/usr/local/opt/libomp/include"
            OMP_LIBS="/usr/local/opt/libomp/lib/libomp.dylib -Wl,-rpath,/usr/local/opt/libomp/lib"
            OVERRIDE_LDFLAGS="-L/usr/local/opt/libomp/lib"
        fi
    fi
    
    # CONFLICT DETECTION: Warn user if ~/.R/Makevars might cause issues
    if [ -f "$HOME/.R/Makevars" ]; then
        if grep -q "usr/local.*omp\|lomp" "$HOME/.R/Makevars" 2>/dev/null; then
            echo ""
            echo "  *** WARNING ***"
            echo "  Your ~/.R/Makevars contains OpenMP flags that may conflict."
            echo "  If installation fails, try: mv ~/.R/Makevars ~/.R/Makevars.bak"
            echo ""
        fi
    fi
else
    # --- Linux Logic ---
    OMP_CFLAGS=$(R CMD config SHLIB_OPENMP_CFLAGS 2>/dev/null)
    OMP_LIBS=$(R CMD config SHLIB_OPENMP_CFLAGS 2>/dev/null)
fi

# Clean up
case "$OMP_CFLAGS" in *ERROR*) OMP_CFLAGS="";; esac
case "$OMP_LIBS" in *ERROR*) OMP_LIBS="";; esac

# 3. WRITE MAKEVARS
mkdir -p src

cat > src/Makevars <<EOF
## Automatically generated by configure
PKG_CFLAGS = $OMP_CFLAGS $GSL_CFLAGS
PKG_LIBS = $OMP_LIBS $GSL_LIBS
EOF

# If we need to override LDFLAGS to prevent conflicts
if [ -n "$OVERRIDE_LDFLAGS" ]; then
    cat >> src/Makevars <<EOF

# Override to prevent conflicts with user ~/.R/Makevars
LDFLAGS = $OVERRIDE_LDFLAGS
EOF
fi

if [ -n "$OMP_CFLAGS" ]; then
    echo "OpenMP enabled."
    echo "  OMP_CFLAGS: $OMP_CFLAGS"
    echo "  OMP_LIBS:   $OMP_LIBS"
else
    echo "WARNING: OpenMP not found. Package will compile without parallelization."
fi

echo "Configuration complete."
